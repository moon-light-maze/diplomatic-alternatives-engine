{
  "name": "conflict-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Daily live-conflict tracker & AI peace-plan generator, powered by Claude Code",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build && npm --workspace server run build",
    "start": "npm --workspace server run start",
    "refresh": "npm --workspace server run refresh --",
    "probe": "npm --workspace server run probe --"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

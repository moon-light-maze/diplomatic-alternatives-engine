<?xml version="1.0" encoding="UTF-8"?>
<!-- Template. install-schedule.sh substitutes __PROJECT__ with the repo's absolute path
     (launchd requires absolute paths) and installs the result into ~/Library/LaunchAgents. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.diplomatic-alternatives.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT__/scripts/run-daily.sh</string>
  </array>

  <!-- Fire at 05:00. launchd uses system-local time; TZ below makes the job Pacific-aware.
       If this Mac is not set to Pacific time, change Hour to your local equivalent of 5am PT. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>5</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>EnvironmentVariables</key>
  <dict>
    <key>TZ</key>
    <string>America/Los_Angeles</string>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>__PROJECT__/data/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT__/data/launchd.err.log</string>
</dict>
</plist>
